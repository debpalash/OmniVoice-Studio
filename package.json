{
  "name": "omnivoice-studio-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "turbo run dev //#dev:api",
    "desktop": "turbo run desktop //#dev:api",
    "build": "turbo run build",
    "start": "turbo run start",
